# ─────────────────────────────────────────────
#  Oracle 26ai – Vector Search App  •  .env
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Oracle connection (python-oracledb thin mode) ─────────────────────────────
ORA_USER=dev
ORA_PASSWORD=your_password_here
ORA_HOST=localhost
ORA_PORT=1521
ORA_SERVICE=DEVPDB

# ── Schema & objects ──────────────────────────────────────────────────────────
ORA_SCHEMA=DEV
ORA_DOC_TABLE=AITEST_DOCUMENTATION_TAB
ORA_CHUNK_TABLE=AITEST_DOCUMENTATION_CHUNKS
ORA_ONNX_MODEL=ALL_MINILM_L12_V2

# ── Vector search ─────────────────────────────────────────────────────────────
VECTOR_TOP_K=5
VECTOR_DISTANCE=COSINE            # COSINE | DOT | EUCLIDEAN

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: ollama | gemini
LLM_PROVIDER=ollama

# ── Ollama (LLM_PROVIDER=ollama) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/api
# Model must be pulled first:  ollama pull gemma4:e4b
# Sampling params for gemma4 (temperature, top_p, top_k) are set automatically
OLLAMA_MODEL=gemma4:e4b

# ── Google Gemini (LLM_PROVIDER=gemini) ───────────────────────────────────────
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use — available models fetched live from the API
# Common choices: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash
# Optional generation config (defaults shown)
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024
